<Window x:Class="LuoluoPiDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LuoluoPiDesktop.Views"
        xmlns:vm="clr-namespace:LuoluoPiDesktop.ViewModels"
        Title="Luoluo Pi Desktop"
        MinWidth="900" MinHeight="600"
        Background="#F5F5F5">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ProjectListViewModel}">
            <views:ProjectListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ChatViewModel}">
            <views:ChatView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 侧边导航栏 -->
        <Border Grid.Column="0"
                Background="#2B2B2B"
                Padding="0,12">
            <StackPanel>
                <TextBlock Text="Luoluo Pi"
                           Foreground="White"
                           FontSize="15"
                           FontWeight="Bold"
                           Margin="16,8,8,20"
                           TextWrapping="Wrap"/>

                <Button Content="项目"
                        Command="{Binding ShowProjectsCommand}"
                        Style="{StaticResource NavButtonStyle}"/>
                <Button Content="对话"
                        Command="{Binding ShowChatCommand}"
                        Style="{StaticResource NavButtonStyle}"/>
                <Button Content="设置"
                        Command="{Binding ShowSettingsCommand}"
                        Style="{StaticResource NavButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- 内容区 -->
        <Border Grid.Column="1" Background="White">
            <ContentControl Content="{Binding CurrentPage}"/>
        </Border>
    </Grid>
</Window>
