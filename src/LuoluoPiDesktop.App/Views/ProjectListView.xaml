<UserControl x:Class="LuoluoPiDesktop.Views.ProjectListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LuoluoPiDesktop.Views">

    <UserControl.Resources>
        <!-- 徽章样式 -->
        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius"  Value="3"/>
            <Setter Property="Padding"       Value="6,2"/>
            <Setter Property="Margin"        Value="0,0,6,0"/>
        </Style>
        <Style x:Key="BadgeText" TargetType="TextBlock">
            <Setter Property="FontSize"      Value="10"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 标题栏 -->
            <RowDefinition Height="Auto"/>  <!-- 添加区域 -->
            <RowDefinition Height="*"/>     <!-- 项目列表 -->
            <RowDefinition Height="Auto"/>  <!-- 操作按钮 -->
            <RowDefinition Height="Auto"/>  <!-- 重命名面板 -->
            <RowDefinition Height="Auto"/>  <!-- 状态栏 -->
        </Grid.RowDefinitions>

        <!-- 标题 + 刷新按钮 -->
        <Grid Grid.Row="0" Margin="20,20,20,12">
            <TextBlock Text="本地项目" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="刷新状态"
                    Command="{Binding RefreshCommand}"
                    HorizontalAlignment="Right"
                    Padding="12,4" FontSize="12"/>
        </Grid>

        <!-- 添加项目区域 -->
        <Border Grid.Row="1"
                Margin="20,0,20,12"
                Background="#F8F8F8"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding InputPath, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         Padding="8,6"
                         FontSize="13"
                         Margin="0,0,8,0"
                         ToolTip="输入项目绝对路径，或点击【浏览】选择目录"/>
                <Button Grid.Column="1"
                        Content="浏览..."
                        Command="{Binding BrowseCommand}"
                        Padding="12,6" FontSize="13" Margin="0,0,6,0"/>
                <Button Grid.Column="2"
                        Content="添加项目"
                        Command="{Binding AddCommand}"
                        Padding="14,6" FontSize="13"/>
            </Grid>
        </Border>

        <!-- 项目卡片列表 -->
        <ListBox Grid.Row="2"
                 Margin="20,0,20,0"
                 ItemsSource="{Binding Items}"
                 SelectedItem="{Binding Selected}"
                 BorderThickness="1"
                 BorderBrush="#E0E0E0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding"    Value="0"/>
                    <Setter Property="Margin"     Value="0"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12,10"
                            BorderBrush="#F0F0F0"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 项目名 + 路径不存在警告 -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Background="#FFEBEB" CornerRadius="3"
                                        Padding="5,1" Margin="8,0,0,0"
                                        Visibility="{Binding PathExists,
                                            Converter={x:Static local:BoolToCollapsedConverter.Instance}}">
                                    <TextBlock Text="目录不存在" Foreground="Red" FontSize="10"/>
                                </Border>
                            </StackPanel>

                            <!-- 路径 -->
                            <TextBlock Grid.Row="1"
                                       Text="{Binding LocalPath}"
                                       Foreground="#666" FontSize="11"
                                       Margin="0,2,0,4"
                                       TextTrimming="CharacterEllipsis"/>

                            <!-- 徽章行 -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                <!-- Git 徽章 -->
                                <Border Style="{StaticResource BadgeStyle}"
                                        Background="#E8F5E9">
                                    <TextBlock Text="{Binding GitBadge}"
                                               Style="{StaticResource BadgeText}"
                                               Foreground="#388E3C"/>
                                </Border>
                                <!-- AGENTS.md 徽章 -->
                                <Border Style="{StaticResource BadgeStyle}"
                                        Background="#E3F2FD">
                                    <TextBlock Text="{Binding AgentsBadge}"
                                               Style="{StaticResource BadgeText}"
                                               Foreground="#1565C0"/>
                                </Border>
                                <!-- 最后使用 -->
                                <TextBlock Text="{Binding LastUsedDisplay}"
                                           Foreground="#999" FontSize="10"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 操作按钮区 -->
        <Grid Grid.Row="3" Margin="20,8,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 主操作：开始对话 -->
            <Button Grid.Column="0"
                    Content="开始对话"
                    Command="{Binding StartChatCommand}"
                    Padding="16,6" FontSize="13" FontWeight="SemiBold"
                    Background="#0078D4" Foreground="White"
                    Margin="0,0,12,0" MinWidth="88"/>

            <!-- 次要操作 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="在资源管理器中打开"
                        Command="{Binding OpenFolderCommand}"
                        Padding="10,5" FontSize="12" Margin="0,0,6,0"/>
                <Button Content="重命名"
                        Command="{Binding StartRenameCommand}"
                        Padding="10,5" FontSize="12" Margin="0,0,6,0"/>
                <Button Content="移除"
                        Command="{Binding RemoveCommand}"
                        Padding="10,5" FontSize="12" Foreground="DarkRed"/>
            </StackPanel>
        </Grid>

        <!-- 重命名面板（折叠/展开） -->
        <Border Grid.Row="4"
                Margin="20,8,20,0"
                Background="#FFF9E6"
                BorderBrush="#FFD54F"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8"
                Visibility="{Binding IsRenaming,
                    Converter={x:Static local:BoolToVisibleConverter.Instance}}">
            <StackPanel>
                <TextBlock Text="输入新名称：" FontSize="12" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4" FontSize="13" Margin="0,0,6,0"/>
                    <Button Grid.Column="1" Content="确认"
                            Command="{Binding ConfirmRenameCommand}"
                            Padding="12,4" FontSize="12" Margin="0,0,6,0"/>
                    <Button Grid.Column="2" Content="取消"
                            Command="{Binding CancelRenameCommand}"
                            Padding="12,4" FontSize="12"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 状态栏 -->
        <TextBlock Grid.Row="5"
                   Text="{Binding StatusMessage}"
                   FontSize="12"
                   Margin="20,6,20,12"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="#555"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsError}" Value="True">
                            <Setter Property="Foreground" Value="#C62828"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</UserControl>
