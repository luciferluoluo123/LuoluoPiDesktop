<UserControl x:Class="LuoluoPiDesktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="640">

            <TextBlock Text="设置" FontSize="20" FontWeight="Bold" Margin="0,0,0,24"/>

            <!-- Codex 路径 -->
            <TextBlock Text="Codex 可执行文件路径" FontSize="13" Margin="0,0,0,4"/>
            <TextBox Text="{Binding CodexExePath, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6" FontSize="13" Margin="0,0,0,16"/>

            <!-- Shell 路径 -->
            <TextBlock Text="Git Bash 路径" FontSize="13" Margin="0,0,0,4"/>
            <TextBox Text="{Binding ShellPath, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6" FontSize="13" Margin="0,0,0,16"/>

            <!-- 默认模型 -->
            <TextBlock Text="默认模型" FontSize="13" Margin="0,0,0,4"/>
            <TextBox Text="{Binding DefaultModel, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6" FontSize="13" Margin="0,0,0,24"/>

            <!-- 保存按钮 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="保存设置"
                        Command="{Binding SaveCommand}"
                        Padding="20,8"
                        FontSize="13"/>
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="Green"
                       FontSize="12"
                       Margin="0,4,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
